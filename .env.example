# obsidian-imgbed 配置模板
# 复制为 .env 后填入你的值，或直接 export 到 shell

# ===== Obsidian 路径 =====
# 图片源目录（待上传的图片所在）
OBSIDIAN_IMG_DIR=/path/to/obsidian/assets/images
# Markdown 笔记根目录
OBSIDIAN_MD_DIR=/path/to/obsidian/markdown

# ===== 阿里云 OSS 凭证 =====
OSS_BUCKET=your-bucket-name
OSS_ENDPOINT=oss-cn-shanghai.aliyuncs.com
OSS_AK=your-access-key-id
OSS_SK=your-access-key-secret
# 上传后的公开 URL 前缀（替换 your-bucket-name 和 region）
OSS_URL_PREFIX=https://your-bucket-name.oss-cn-shanghai.aliyuncs.com/

# ===== 数据库 =====
OSS_MANIFEST_DB=manifest.db

# ===== 可选：上传参数 =====
UPLOAD_THREADS=8
